// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // 或者 "mysql", "sqlite" 等
  url      = env("DATABASE_URL")
}

model User {
  id         Int            @id @default(autoincrement())
  email      String         @unique
  username   String
  password   String
  avatar     String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  
  // 关系
  playlists  Playlist[]
  favorites  UserFavorite[]
  comments   Comment[]
  albums     Album[]
}

model Album {
  id          Int      @id @default(autoincrement())
  name        String
  coverUrl    String
  type        String
  version     String?
  releaseDate DateTime
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 关系
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  songs       Song[]   // 一个专辑包含多首歌曲
}

model Song {
  id          Int      @id @default(autoincrement())
  title       String
  artist      String
  audioUrl    String
  coverUrl    String
  duration    Float
  lyrics      String?
  playCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // --- FIX: Made the relationship to Album required ---
  albumId     Int      // Changed from Int? to Int
  album       Album    @relation(fields: [albumId], references: [id], onDelete: Cascade) // Changed from Album? to Album

  // Relationships that will be deleted when a Song is deleted
  comments    Comment[]
  favorites   UserFavorite[]
  playlists   PlaylistSong[]
}

model Playlist {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  isPublic    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  userId      Int
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade) // Added Cascade for user deletion
  songs       PlaylistSong[]
}

model PlaylistSong {
  id         Int      @id @default(autoincrement())
  playlistId Int
  songId     Int
  addedAt    DateTime @default(now())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song       Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
}

model UserFavorite {
  id     Int      @id @default(autoincrement())
  userId Int
  songId Int
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  song   Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  userId    Int
  songId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
}